# Cloud LLM — use OpenAI and/or Groq (free tier: https://console.groq.com/keys)
# ChatGPT “free” web login is NOT an API key; use keys from the consoles below.
OPENAI_API_KEY=
# Leave empty for api.openai.com; set for OpenRouter etc. (must end with /v1)
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
# auto | openai | groq | ollama  (auto prefers OpenAI key, then Groq, then Ollama)
LLM_PROVIDER=auto

# Local LLM (Ollama) — used when no cloud keys or LLM_PROVIDER=ollama or OLLAMA_ONLY=1
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_ONLY=0
